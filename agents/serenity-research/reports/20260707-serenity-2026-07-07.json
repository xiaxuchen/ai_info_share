  "content": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Serenity 紫苏叶逆向投研日报 — 2026年7月7日</title>\n<style>\n  :root {\n    --bg: #0d1117;\n    --card: #161b22;\n    --border: #30363d;\n    --text: #e6edf3;\n    --muted: #8b949e;\n    --accent: #f0883e;\n    --green: #3fb950;\n    --red: #f85149;\n    --blue: #58a6ff;\n    --purple: #bc8cff;\n    --yellow: #d29922;\n    --pink: #f778ba;\n  }\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body {\n    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans CJK SC', sans-serif;\n    background: var(--bg);\n    color: var(--text);\n    line-height: 1.7;\n    padding: 20px;\n    max-width: 1200px;\n    margin: 0 auto;\n  }\n  .header {\n    text-align: center;\n    padding: 40px 0 30px;\n    border-bottom: 1px solid var(--border);\n    margin-bottom: 30px;\n    background: linear-gradient(135deg, rgba(240,136,62,0.1), rgba(188,140,255,0.1));\n    border-radius: 16px;\n  }\n  .header h1 {\n    font-size: 28px;\n    background: linear-gradient(90deg, var(--accent), var(--purple));\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    margin-bottom: 8px;\n  }\n  .header .subtitle {\n    color: var(--muted);\n    font-size: 14px;\n  }\n  .header .meta {\n    margin-top: 12px;\n    display: flex;\n    justify-content: center;\n    gap: 24px;\n    flex-wrap: wrap;\n  }\n  .header .meta span {\n    background: rgba(255,255,255,0.06);\n    padding: 4px 14px;\n    border-radius: 20px;\n    font-size: 13px;\n    color: var(--muted);\n  }\n  .section {\n    background: var(--card);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    padding: 28px;\n    margin-bottom: 24px;\n  }\n  .section-title {\n    font-size: 20px;\n    font-weight: 700;\n    margin-bottom: 20px;\n    padding-bottom: 12px;\n    border-bottom: 2px solid var(--border);\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n  .section-title .icon {\n    width: 32px; height: 32px;\n    border-radius: 8px;\n    display: flex; align-items: center; justify-content: center;\n    font-size: 16px;\n  }\n  .icon-fire { background: rgba(248,81,73,0.2); }\n  .icon-doc { background: rgba(88,166,255,0.2); }\n  .icon-filter { background: rgba(188,140,255,0.2); }\n  .icon-chart { background: rgba(63,185,80,0.2); }\n  .icon-strategy { background: rgba(240,136,62,0.2); }\n  .icon-review { background: rgba(210,153,34,0.2); }\n\n  .market-index-row {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n    gap: 16px;\n    margin-bottom: 24px;\n  }\n  .idx-card {\n    background: rgba(255,255,255,0.04);\n    border-radius: 10px;\n    padding: 16px;\n    text-align: center;\n    border: 1px solid var(--border);\n  }\n  .idx-card .name { font-size: 13px; color: var(--muted); }\n  .idx-card .val { font-size: 22px; font-weight: 700; margin: 4px 0; }\n  .idx-card .chg { font-size: 14px; font-weight: 600; }\n  .up { color: var(--green); }\n  .down { color: var(--red); }\n\n  .hot-boards {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));\n    gap: 16px;\n    margin-top: 16px;\n  }\n  .board-card {\n    background: rgba(255,255,255,0.03);\n    border-radius: 10px;\n    padding: 18px;\n    border: 1px solid var(--border);\n  }\n  .board-card h4 {\n    font-size: 15px;\n    margin-bottom: 10px;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n  .board-card ul { list-style: none; }\n  .board-card li {\n    font-size: 13px;\n    color: var(--muted);\n    padding: 3px 0;\n    border-bottom: 1px solid rgba(255,255,255,0.04);\n  }\n  .board-card li:last-child { border-bottom: none; }\n  .board-card li strong { color: var(--text); }\n  .tag {\n    display: inline-block;\n    padding: 2px 8px;\n    border-radius: 4px;\n    font-size: 11px;\n    font-weight: 600;\n  }\n  .tag-hot { background: rgba(248,81,73,0.2); color: var(--red); }\n  .tag-policy { background: rgba(88,166,255,0.2); color: var(--blue); }\n  .tag-money { background: rgba(63,185,80,0.2); color: var(--green); }\n  .tag-event { background: rgba(188,140,255,0.2); color: var(--purple); }\n\n  table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 14px;\n  }\n  th {\n    text-align: left;\n    padding: 10px 12px;\n    background: rgba(255,255,255,0.05);\n    border-bottom: 2px solid var(--border);\n    font-weight: 600;\n    font-size: 13px;\n    color: var(--muted);\n    white-space: nowrap;\n  }\n  td {\n    padding: 10px 12px;\n    border-bottom: 1px solid rgba(255,255,255,0.04);\n    vertical-align: middle;\n  }\n  tr:hover td { background: rgba(255,255,255,0.02); }\n  .stock-name { font-weight: 600; color: var(--text); }\n  .stock-code { color: var(--muted); font-size: 12px; }\n  .score-badge {\n    display: inline-block;\n    padding: 3px 10px;\n    border-radius: 12px;\n    font-weight: 700;\n    font-size: 14px;\n  }\n  .score-high { background: rgba(63,185,80,0.2); color: var(--green); }\n  .score-mid { background: rgba(240,136,62,0.2); color: var(--accent); }\n  .score-low { background: rgba(248,81,73,0.2); color: var(--red); }\n  .rating-tag {\n    display: inline-block;\n    padding: 2px 10px;\n    border-radius: 4px;\n    font-size: 12px;\n    font-weight: 600;\n  }\n  .rating-buy { background: rgba(63,185,80,0.15); color: var(--green); }\n  .rating-watch { background: rgba(210,153,34,0.15); color: var(--yellow); }\n  .rating-sell { background: rgba(248,81,73,0.15); color: var(--red); }\n  .rating-hold { background: rgba(88,166,255,0.15); color: var(--blue); }\n\n  .triangle-viz {\n    display: flex;\n    gap: 20px;\n    margin: 20px 0;\n    flex-wrap: wrap;\n  }\n  .tri-col {\n    flex: 1;\n    min-width: 200px;\n    background: rgba(255,255,255,0.03);\n    border-radius: 10px;\n    padding: 16px;\n    border: 1px solid var(--border);\n  }\n  .tri-col h5 { text-align: center; margin-bottom: 12px; font-size: 14px; }\n  .bar-group { margin: 8px 0; }\n  .bar-label { font-size: 12px; color: var(--muted); margin-bottom: 3px; display: flex; justify-content: space-between; }\n  .bar-track { background: rgba(255,255,255,0.08); border-radius: 4px; height: 8px; overflow: hidden; }\n  .bar-fill { height: 100%; border-radius: 4px; transition: width 0.5s; }\n  .bar-green { background: linear-gradient(90deg, #238636, var(--green)); }\n  .bar-blue { background: linear-gradient(90deg, #1f6feb, var(--blue)); }\n  .bar-purple { background: linear-gradient(90deg, #8b5cf6, var(--purple)); }\n\n  .strategy-cards {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));\n    gap: 16px;\n  }\n  .strat-card {\n    background: rgba(255,255,255,0.03);\n    border-radius: 10px;\n    padding: 20px;\n    border: 1px solid var(--border);\n    position: relative;\n  }\n  .strat-card .rank {\n    position: absolute;\n    top: -1px; left: -1px;\n    background: var(--accent);\n    color: #fff;\n    font-size: 12px;\n    font-weight: 700;\n    padding: 3px 10px;\n    border-radius: 10px 0 10px 0;\n  }\n  .strat-card h4 { font-size: 16px; margin-bottom: 4px; padding-top: 4px; }\n  .strat-card .track { color: var(--muted); font-size: 13px; margin-bottom: 12px; }\n  .strat-card .detail { font-size: 13px; color: var(--muted); margin: 6px 0; }\n  .strat-card .detail strong { color: var(--text); }\n  .strat-card .action-box {\n    background: rgba(63,185,80,0.08);\n    border: 1px solid rgba(63,185,80,0.2);\n    border-radius: 8px;\n    padding: 12px;\n    margin-top: 12px;\n    font-size: 13px;\n  }\n  .strat-card .action-box.warn {\n    background: rgba(210,153,34,0.08);\n    border-color: rgba(210,153,34,0.2);\n  }\n  .strat-card .action-box.danger {\n    background: rgba(248,81,73,0.08);\n    border-color: rgba(248,81,73,0.2);\n  }\n\n  .review-summary {\n    background: rgba(210,153,34,0.06);\n    border: 1px solid rgba(210,153,34,0.15);\n    border-radius: 10px;\n    padding: 16px;\n    margin-bottom: 20px;\n    font-size: 14px;\n  }\n  .review-summary h4 { color: var(--yellow); margin-bottom: 8px; }\n\n  .perf-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n    gap: 16px;\n    margin-top: 16px;\n  }\n  .perf-card {\n    background: rgba(255,255,255,0.03);\n    border-radius: 10px;\n    padding: 16px;\n    border: 1px solid var(--border);\n  }\n  .perf-card h5 { font-size: 14px; margin-bottom: 8px; }\n  .perf-card .metric {\n    display: flex;\n    justify-content: space-between;\n    padding: 4px 0;\n    border-bottom: 1px solid rgba(255,255,255,0.04);\n    font-size: 13px;\n  }\n  .perf-card .metric:last-child { border-bottom: none; }\n\n  .policy-list {\n    list-style: none;\n    counter-reset: policy;\n  }\n  .policy-list li {\n    counter-increment: policy;\n    padding: 12px 0 12px 40px;\n    position: relative;\n    border-left: 2px solid var(--border);\n    margin-left: 14px;\n    font-size: 14px;\n  }\n  .policy-list li::before {\n    content: counter(policy);\n    position: absolute;\n    left: -11px;\n    top: 14px;\n    width: 20px; height: 20px;\n    background: var(--accent);\n    color: #fff;\n    border-radius: 50%;\n    font-size: 11px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: 700;\n  }\n  .policy-list li strong { color: var(--blue); }\n\n  .disclaimer {\n    background: rgba(248,81,73,0.06);\n    border: 1px solid rgba(248,81,73,0.15);\n    border-radius: 10px;\n    padding: 20px;\n    margin-top: 30px;\n    font-size: 12px;\n    color: var(--muted);\n    line-height: 1.8;\n  }\n  .disclaimer h4 {\n    color: var(--red);\n    font-size: 14px;\n    margin-bottom: 8px;\n  }\n\n  .highlight-box {\n    background: rgba(240,136,62,0.08);\n    border: 1px solid rgba(240,136,62,0.2);\n    border-radius: 10px;\n    padding: 16px;\n    margin: 16px 0;\n    font-size: 14px;\n  }\n  .highlight-box strong { color: var(--accent); }\n\n  .highlight-box.green {\n    background: rgba(63,185,80,0.08);\n    border-color: rgba(63,185,80,0.2);\n  }\n  .highlight-box.green strong { color: var(--green); }\n\n  .highlight-box.red {\n    background: rgba(248,81,73,0.08);\n    border-color: rgba(248,81,73,0.2);\n  }\n  .highlight-box.red strong { color: var(--red); }\n\n  .funds-flow {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\n    gap: 12px;\n    margin-top: 12px;\n  }\n  .fund-item {\n    background: rgba(255,255,255,0.03);\n    border-radius: 8px;\n    padding: 12px;\n    text-align: center;\n    border: 1px solid var(--border);\n  }\n  .fund-item .label { font-size: 12px; color: var(--muted); }\n  .fund-item .value { font-size: 18px; font-weight: 700; margin-top: 4px; }\n\n  .note { font-size: 12px; color: var(--muted); margin-top: 12px; font-style: italic; }\n  .critical-warning {\n    background: rgba(248,81,73,0.1);\n    border: 2px solid rgba(248,81,73,0.3);\n    border-radius: 12px;\n    padding: 20px;\n    margin: 20px 0;\n    font-size: 14px;\n  }\n  .critical-warning h4 { color: var(--red); margin-bottom: 10px; font-size: 16px; }\n</style>\n</head>\n<body>\n\n<div class=\"header\">\n  <h1>Serenity 紫苏叶逆向投研日报</h1>\n  <div class=\"subtitle\">2026年7月7日（周二） | 高位题材崩塌 · 风格切换 · 框架纠偏</div>\n  <div class=\"meta\">\n    <span>紫苏叶理论 v3.1</span>\n    <span>逆向投研框架</span>\n    <span>数据截止：2026-07-06 收盘</span>\n    <span>第11期</span>\n  </div>\n</div>\n\n<!-- ===================== SECTION 1: 市场热点概览 ===================== -->\n<div class=\"section\">\n  <div class=\"section-title\">\n    <span class=\"icon icon-fire\">🔥</span> 市场热点概览\n  </div>\n\n  <div class=\"market-index-row\">\n    <div class=\"idx-card\">\n      <div class=\"name\">上证指数</div>\n      <div class=\"val\">4,041.24</div>\n      <div class=\"chg down\">-0.06%</div>\n    </div>\n    <div class=\"idx-card\">\n      <div class=\"name\">深证成指</div>\n      <div class=\"val\">15,416.80</div>\n      <div class=\"chg down\">-1.16%</div>\n    </div>\n    <div class=\"idx-card\">\n      <div class=\"name\">创业板指</div>\n      <div class=\"val\">3,948.86</div>\n      <div class=\"chg down\">-1.77%</div>\n    </div>\n    <div class=\"idx-card\">\n      <div class=\"name\">科创50</div>\n      <div class=\"val\">1,960.50</div>\n      <div class=\"chg down\">-0.72%</div>\n    </div>\n    <div class=\"idx-card\">\n      <div class=\"name\">北证50</div>\n      <div class=\"val\">—</div>\n      <div class=\"chg down\">-0.35%</div>\n    </div>\n  </div>\n\n  <div class=\"highlight-box red\">\n    <strong>核心结论：</strong>7月6日（周一）A股上演\"利好兑现即利空\"。央行万亿逆回购+A股交易新规双利好落地，但三大指数高开低走集体收跌。上证微跌0.06%守4000点，深成指、创业板均跌超1%。两市成交3.09万亿（缩量913亿），超3500只个股下跌，51只跌停，炸板率高达38%。资金从高位机器人、半导体、光通信赛道大规模出逃，切换至低位防御（煤炭+4.11%、银行）+国产算力（紫光股份、中国长城涨停）+医药生物（恒瑞医药+4.26%）。市场风格发生剧烈切换，Serenity框架面临严峻考验。\n  </div>\n\n  <h4 style=\"margin: 20px 0 12px; font-size: 15px;\">🔥 主线热点与板块分布（7月6日收盘）</h4>\n  <div class=\"hot-boards\">\n    <div class=\"board-card\">\n      <h4><span class=\"tag tag-hot\">主线</span> 医药生物/创新药（全场最强）</h4>\n      <ul>\n        <li>医药生物板块净流入 <strong>+62.36亿</strong>，居全行业首位</li>\n        <li>恒瑞医药大涨 <strong>+4.26%</strong>，成交101亿，主力净流入近9亿</li>\n        <li>首药控股盘中 <strong>20CM涨停</strong>，收盘+14.67%</li>\n        <li>创新药、仿制药、细胞治疗全线爆发，政策底+估值底双重催化</li>\n      </ul>\n    </div>\n    <div class=\"board-card\">\n      <h4><span class=\"tag tag-hot\">主线</span> 国产算力逆势抱团</h4>\n      <ul>\n        <li>紫光股份涨停，主力净流入 <strong>+15.72亿</strong></li>\n        <li>中国长城涨停，主力净流入 <strong>+10.16亿</strong></li>\n        <li>计算机板块净流入 <strong>+13.26亿</strong>，居申万一级行业首位</li>\n        <li>高位半导体/光模块出逃，资金抱团国产算力硬件</li>\n      </ul>\n    </div>\n    <div class=\"board-card\">\n      <h4><span class=\"tag tag-policy\">政策</span> 煤炭/银行（低位防御）</h4>\n      <ul>\n        <li>煤炭板块大涨 <strong>+4.11%</strong>，领涨全市场</li>\n        <li>银行净流入 <strong>+14.77亿</strong>，招商银行+3.41亿</li>\n        <li>资金从成长股流向高股息防御板块</li>\n        <li>中报业绩确定性+高股息避险逻辑</li>\n      </ul>\n    </div>\n    <div class=\"board-card\">\n      <h4><span class=\"tag tag-money\">资金</span> EDA/半导体设备（分化）</h4>\n      <ul>\n        <li>概伦电子 <strong>20CM涨停</strong>，华大九天涨近15%</li>\n        <li>华为\"韬定律\"升级催化EDA国产替代</li>\n        <li>但存储芯片、光通信大面积回调</li>\n        <li>电子行业净流出 <strong>-291.83亿</strong></li>\n      </ul>\n    </div>\n    <div class=\"board-card\">\n      <h4><span class=\"tag tag-event\">事件</span> 创新药政策催化</h4>\n      <ul>\n        <li>医保商保目录优化预期+创新药出海放量</li>\n        <li>首药控股、罗欣药业、艾迪药业等批量涨停/大涨</li>\n        <li>板块估值处于历史低位，机构低配回补</li>\n        <li>7月下旬卡瑞利珠单抗等重磅品种预期</li>\n      </ul>\n    </div>\n    <div class=\"board-card\">\n      <h4><span class=\"tag tag-policy\">政策</span> 并购重组（恒尚节能）</h4>\n      <ul>\n        <li>恒尚节能 <strong>5连板</strong>，7月7日冲击6连板</li>\n        <li>宜宾纸业4连板，新材料转型+扭亏为盈</li>\n        <li>金科股份3连板</li>\n        <li>重组预期是市场弱势中的资金避风港</li>\n      </ul>\n    </div>\n  </div>\n\n  <h4 style=\"margin: 24px 0 12px; font-size: 15px;\">⚠️ 资金出逃板块（7月6日）</h4>\n  <table>\n    <tr>\n      <th>板块</th>\n      <th>7/6净流出</th>\n      <th>核心出逃标的</th>\n    </tr>\n    <tr>\n      <td>电子/半导体</td>\n      <td class=\"down\">-291.83亿</td>\n      <td>兆易创新(-41亿)、中际旭创(-26亿)</td>\n    </tr>\n    <tr>\n      <td>通信/光模块</td>\n      <td class=\"down\">-131.00亿</td>\n      <td>亨通光电、新易盛等高位兑现</td>\n    </tr>\n    <tr>\n      <td>人形机器人</td>\n      <td class=\"down\">-89.50亿</td>\n      <td>五洲新春跌停、大业股份跌停、拓斯达-15%</td>\n    </tr>\n    <tr>\n      <td>光通信/PCB</td>\n      <td class=\"down\">-68.30亿</td>\n      <td>玻璃基板概念下挫，彩虹股份跌停</td>\n    </tr>\n    <tr>\n      <td>光伏/储能</td>\n      <td class=\"down\">-45.20亿</td>\n      <td>产能过剩担忧持续，高位赛道集体回调</td>\n    </tr>\n  </table>\n\n  <div class=\"funds-flow\">\n    <div class=\"fund-item\">\n      <div class=\"label\">7/6主力净流出</div>\n      <div class=\"value down\">-744.65亿</div>\n    </div>\n    <div class=\"fund-item\">\n      <div class=\"label\">7/6涨停家数</div>\n      <div class=\"value\">71只</div>\n    </div>\n    <div class=\"fund-item\">\n      <div class=\"label\">7/6跌停家数</div>\n      <div class=\"value down\">51只</div>\n    </div>\n    <div class=\"fund-item\">\n      <div class=\"label\">两市成交额</div>\n      <div class=\"value\">3.09万亿</div>\n    </div>\n  </div>\n\n  <h4 style=\"margin: 24px 0 12px; font-size: 15px;\">📅 重大政策与事件催化（7月7日周二前瞻）</h4>\n  <ul class=\"policy-list\">\n    <li><strong>央行1万亿买断式逆回购已落地：</strong>7月6日执行后，净投放2000亿元中长期资金，但市场反应冷淡，高开低走。短期流动性利好已消化，后续关注MLF续作情况。</li>\n    <li><strong>A股交易新规首日施行：</strong>盘后固定价格交易扩展至全部A股；主板ST股涨跌幅5%→10%。首日ST板块波动可控，但后续需警惕风险个股流动性变化。</li>\n    <li><strong>创新药政策底确认：</strong>医保谈判边际缓和+创新药出海放量+估值历史低位，7月6日医药生物净流入62亿居首。关注7月下旬重磅品种审批进展。</li>\n    <li><strong>华为\"韬定律\"升级催化EDA：</strong>概伦电子20CM涨停、华大九天涨近15%。国产EDA替代逻辑强化，但标的市值普遍偏大，Serenity冷门性不足。</li>\n    <li><strong>中报业绩预告密集披露期开启：</strong>7月6日至7月31日为中报预告集中期，业绩确定性成为资金首要考量。煤炭、银行等高股息板块受益。</li>\n    <li><strong>7月18日中船特气率先披露半年报：</strong>沪市半年报预约披露时间出炉，中船特气拔得头筹。关注电子特气板块业绩验证。</li>\n    <li><strong>前瞻事件 — 7月18日上海世界人工智能大会：</strong>多款人形机器人新品发布预期，但7月6日机器人板块已大跌，短期情绪脆弱，中期催化仍存。</li>\n  </ul>\n</div>\n\n<!-- ===================== SECTION 2: 研报匹配 ===================== -->\n<div class=\"section\">\n  <div class=\"section-title\">\n    <span class=\"icon icon-doc\">📑</span> 研报匹配\n  </div>\n  <div class=\"highlight-box\">\n    <strong>说明：</strong>工作区研报库（0-公司深度/、1-细分行业&产业链分析/、2-公司PK/）在当前环境中未找到实体文件，以下为基于历史Serenity日报（第1-10期）及公开市场研报信息，匹配与当前热点相关的研究结论。\n  </div>\n  <table>\n    <tr>\n      <th>热点赛道</th>\n      <th>相关研报主题</th>\n      <th>核心结论</th>\n      <th>关联标的</th>\n    </tr>\n    <tr>\n      <td>电子特气/WF6</td>\n      <td>日本两大巨头永久停产WF6（连续6期日报追踪）</td>\n      <td>全球WF6供应缺口扩大，国产替代紧迫性升级。凯美特气是国内WF6龙头，但市值122亿略超Serenity标准</td>\n      <td>凯美特气、三孚股份</td>\n    </tr>\n    <tr>\n      <td>光刻胶配套试剂</td>\n      <td>光刻胶配套（连续4期追踪）</td>\n      <td>东曹断供氧化锆+高端溶剂涨140%+，西陇科学是试剂细分龙头。7月6日随大盘回调-5.93%，但市值仅54亿仍极度冷门</td>\n      <td>西陇科学、彤程新材</td>\n    </tr>\n    <tr>\n      <td>创新药/JAK2抑制剂</td>\n      <td>创新药困境反转（历史专题）+ 首药控股管线分析</td>\n      <td>首药控股JAK2抑制剂类抗肿瘤新药合作研发模式调整，市值66.92亿。7月6日大涨14.67%验证创新药板块回暖</td>\n      <td>首药控股、恒瑞医药、罗欣药业</td>\n    </tr>\n    <tr>\n      <td>国产算力/服务器</td>\n      <td>工业富联/紫光股份/中国长城研报</td>\n      <td>7月6日国产算力逆势抱团，紫光股份、中国长城涨停。但标的市值偏大（紫光股份千亿级），不符合Serenity冷门性</td>\n      <td>紫光股份、中国长城、浪潮信息</td>\n    </tr>\n    <tr>\n      <td>EDA/半导体设备</td>\n      <td>华为\"韬定律\"催化国产EDA</td>\n      <td>概伦电子20CM涨停、华大九天涨近15%。EDA是半导体设计核心工具，国产替代空间大。概伦电子市值超200亿偏大</td>\n      <td>概伦电子、华大九天</td>\n    </tr>\n    <tr>\n      <td>煤炭/高股息</td>\n      <td>中报业绩确定性+高股息策略</td>\n      <td>煤炭板块+4.11%领涨全市场，资金避险需求强烈。但周期股不符合Serenity刚需+稀缺框架</td>\n      <td>中国神华、陕西煤业</td>\n    </tr>\n    <tr>\n      <td>医药生物/CXO</td>\n      <td>创新药困境反转（连续5期追踪）</td>\n      <td>7月6日医药生物净流入62亿居首，恒瑞医药+4.26%。医保谈判边际缓和+估值历史低位+机构低配回补</td>\n      <td>恒瑞医药、首药控股、艾迪药业</td>\n    </tr>\n  </table>\n</div>\n\n<!-- ===================== SECTION 3: Serenity 紫苏叶筛选 ===================== -->\n<div class=\"section\">\n  <div class=\"section-title\">\n    <span class=\"icon icon-filter\">🌿</span> Serenity 紫苏叶筛选\n  </div>\n\n  <div class=\"critical-warning\">\n    <h4>🚨 框架重大纠偏公告</h4>\n    <p>经7月6日市场验证及数据复核，发现第10期报告中<strong>多只标的市值数据存在严重错误</strong>，导致Serenity冷门性评估完全失效：</p>\n    <p>• 绿的谐波：报告写\"市值~68亿\"，<strong>实际市值约894亿</strong>（7月3日数据），冷门性=0</p>\n    <p>• 中船特气：报告写\"市值~85亿\"，<strong>实际市值约1747亿</strong>，冷门性=0</p>\n    <p>• 拓斯达：报告写\"市值167亿\"，实际市值214.69亿，冷门性=0</p>\n    <p>• 凯美特气：报告写\"市值140亿\"，实际市值122.45亿，略超100亿标准</p>\n    <p><strong>后果：</strong>7月6日所有推荐标的全部大跌（西陇科学-5.93%、绿的谐波-6.97%、凯美特气-6.43%、中船特气-8.28%、拓斯达-15.01%），验证率<strong>0%</strong>。根本原因是标的根本不是\"冷门小盘股\"，而是大盘成长股，在市场风格切换至防御时必然大幅回撤。</p>\n    <p><strong>整改措施：</strong>从本期起，所有标的市值数据必须通过东方财富/同花顺等权威来源交叉验证，市值>100亿标的严格执行剔除，杜绝估算错误。</p>\n  </div>\n\n  <div class=\"triangle-viz\">\n    <div class=\"tri-col\">\n      <h5 style=\"color: var(--green);\">🟢 刚需性</h5>\n      <div class=\"bar-group\">\n        <div class=\"bar-label\"><span>西陇科学（光刻胶配套试剂）</span><span>88%</span></div>\n        <div class=